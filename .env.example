# Feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Backend
APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8080
LOG_LEVEL=INFO
SQLITE_PATH=data/state/feishu_rag.sqlite3

# Embedding
EMBEDDING_BASE_URL=http://127.0.0.1:8002
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_TIMEOUT_SECONDS=60

# Milvus
MILVUS_URI=http://127.0.0.1:19530
MILVUS_DB=default
MILVUS_COLLECTION=feishu_chunks_v1
MILVUS_TIMEOUT_SECONDS=5

# Reranker
RERANKER_BASE_URL=http://127.0.0.1:8003
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TIMEOUT_SECONDS=60

# LLM
LLM_BASE_URL=http://127.0.0.1:8004/v1
LLM_MODEL=Qwen3.6-27B-GGUF:Q4_K_M
LLM_TIMEOUT_SECONDS=120
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
